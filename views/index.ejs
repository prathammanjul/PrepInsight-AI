<% layout("/layouts/boilerplate") %>

<style>
  /* HERO FULL SCREEN */
</style>

<div class="hero">
  <div class="hero-content">
    <div class="aiTag">✨ AI-Powered Interview Prep</div>

    <h1 class="hero-title">Ace your next <span>tech interview</span></h1>

    <p class="hero-sub">
      Practice with AI-generated questions, get instant feedback on your
      answers, and track your improvement over time.
    </p>

    <div class="hero-buttons">
      <a href="/interview" class="btn-primary"> Start Practicing → </a>
      <a href="/performance" class="btn-secondary"> View Dashboard </a>
    </div>
  </div>
</div>

<!-- STAT SECTION  -->
<div class="stats-section">
  <div class="stat-box">
    <h2>10K+</h2>
    <p>Questions Generated</p>
  </div>

  <div class="stat-box">
    <h2>95%</h2>
    <p>User Satisfaction</p>
  </div>

  <div class="stat-box">
    <h2>50+</h2>
    <p>Topics Covered</p>
  </div>

  <div class="stat-box">
    <h2>2x</h2>
    <p>Faster Improvement</p>
  </div>
</div>

<!-- ABOUT  -->

<div class="bottom">
  <!-- HEADING -->
  <div class="bottom-header">
    <h2>Everything you need to <span>prepare</span></h2>
    <p>
      A complete toolkit designed to make your interview preparation efficient
      and effective.
    </p>
  </div>

  <!-- CARDS -->
  <div class="feature-grid">
    <div class="feature-card">
      <div class="icon">🧠</div>
      <h4>AI-Powered Questions</h4>
      <p>
        Unique questions generated every time, tailored to your chosen topic.
      </p>
    </div>

    <div class="feature-card">
      <div class="icon">⚡</div>
      <h4>Instant Feedback</h4>
      <p>Get detailed scoring, strengths, and improvements in seconds.</p>
    </div>

    <div class="feature-card">
      <div class="icon">⏱</div>
      <h4>Timed Practice</h4>
      <p>Simulate real interview pressure with countdown timers.</p>
    </div>

    <div class="feature-card">
      <div class="icon">📊</div>
      <h4>Performance Analytics</h4>
      <p>Track your progress and identify areas to improve.</p>
    </div>
  </div>

  <!-- CTA SECTION -->
  <div class="cta-section">
    <div class="cta-card">
      <h2>Ready to level up?</h2>

      <p>
        Start practicing today and transform your interview performance with
        AI-powered feedback.
      </p>

      <a href="/interview" class="cta-btn"> Start Free Practice → </a>
    </div>
  </div>
</div>
