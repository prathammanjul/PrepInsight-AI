<% layout("/layouts/boilerplate") %>

<div class="container text-center mt-5">
  <h1>AI Interview Prep + Resume Analyzer 🚀</h1>
  <p class="mt-3">Practice interviews and improve with AI</p>

  <!-- AUTH BUTTONS -->
  <div class="mt-4">
    <% if (!currUser) { %>
      <a href="/signup" class="btn btn-primary">Sign Up</a>
      <a href="/login" class="btn btn-success">Login</a>
    <% } else { %>
      <a href="/logout" class="btn btn-danger">Logout</a>
    <% } %>
  </div>

  <!-- TOPIC SELECTION -->
  <% if (currUser) { %>

    <div class="mt-5">
      <h5 class="mb-3">Choose Interview Topic</h5>

      <div class="d-flex justify-content-center gap-3 flex-wrap">

        <a href="/interview/frontend" class="btn btn-outline-primary">
          🎨 Frontend
        </a>

        <a href="/interview/backend" class="btn btn-outline-success">
          ⚙️ Backend
        </a>

        <a href="/interview/java" class="btn btn-outline-dark">
          ☕ Java
        </a>

      </div>
    </div>

    <!-- VIEW ANSWERS BUTTON -->
    <div class="mt-4">
      <a href="/answers" class="btn btn-outline-dark">
        📊 View My Answers
      </a>
    </div>

  <% } else { %>

    <!-- NOT LOGGED IN -->
    <div class="mt-4">
      <a href="/login" class="btn btn-warning">
        Login to Start Interview
      </a>
    </div>

  <% } %>

</div>