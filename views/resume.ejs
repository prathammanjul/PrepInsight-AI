<% layout("/layouts/boilerplate") %>
<style>
  /* ================= PAGE ================= */
  .resume-page {
    min-height: 100vh;
    padding: 60px 20px;
    background:
      radial-gradient(circle at 50% 30%, rgba(0, 0, 0, 0.15), transparent 55%),
      radial-gradient(
        circle at 60% 50%,
        rgba(11, 11, 17, 0.1),
        transparent 60%
      ),
      #151414;
    color: white;
  }

  /* ================= HEADER ================= */
  .top-content {
    text-align: center;
    margin-bottom: 50px;
  }

  .header {
    font-size: 2.8rem;
    font-weight: 600;
    margin: 10px 0;
    color: #38bdf8;
  }

  .top-content p {
    color: #94a3b8;
    max-width: 550px;
    margin: auto;
  }

  /* ================= GRID ================= */
  .middle-container {
    max-width: 900px;
    margin: auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
  }

  /* ================= CARD ================= */
  .resume-container {
    padding: 25px;
    border-radius: 16px;

    background: rgba(89, 84, 84, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.08);

    transition: 0.3s;
    /* background-color: #161718; */
  }

  .resume-container:hover {
    border-color: rgba(56, 189, 248, 0.4);
    box-shadow: 0 0 25px rgba(56, 189, 248, 0.1);
    background-color: #161718;
  }

  .resume-container h5 {
    margin-bottom: 5px;
  }

  .resume-container p {
    color: #94a3b8;
    font-size: 14px;
    margin-bottom: 15px;
  }

  /* ================= UPLOAD ================= */
  .upload-box {
    border: 1px dashed rgba(255, 255, 255, 0.2);
    border-radius: 12px;
    padding: 25px;
    text-align: center;
    margin-bottom: 15px;
    color: #94a3b8;
  }

  .upload-box span {
    color: #38bdf8;
    cursor: pointer;
  }

  /* ================= TEXTAREA ================= */
  textarea {
    width: 100%;
    height: 250px;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 10px;
    background: transparent;
    color: white;
    outline: none;
    background-color: #161718;
  }

  .jd-box {
    height: 400px;
  }

  /* ================= DIVIDER ================= */
  .divider {
    text-align: center;
    font-size: 12px;
    margin: 10px 0;
    color: #64748b;
  }

  /* ================= BUTTON ================= */
  .analyze-btn {
    text-align: center;
    margin-top: 40px;
  }

  .analyze-btn button {
    padding: 12px 30px;
    border-radius: 10px;
    border: none;

    background: linear-gradient(135deg, #3b82f6, #06b6d4);
    color: white;
    font-weight: 500;
    cursor: pointer;
    transition: 0.3s;
  }

  .analyze-btn button:hover {
    transform: scale(1.05);
  }

  /* ================= RESPONSIVE ================= */

  /* TABLET */
  @media (max-width: 900px) {
    .middle-container {
      grid-template-columns: 1fr;
    }
  }

  /* MOBILE */
  @media (max-width: 500px) {
    .header {
      font-size: 2rem;
    }

    textarea {
      height: 120px;
    }

    .jd-box {
      height: 180px;
    }
  }
</style>

<% layout("/layouts/boilerplate") %>

<div class="resume-page">
  <!-- HEADER -->
  <div class="top-content">
    <div class="aiTag">✨ AI-Powered Analysis</div>
    <h1 class="header">Resume Analyzer</h1>
    <p>
      Compare your resume against any job description and get actionable
      insights to land your dream role.
    </p>
  </div>

  <form
    action="/resume-analyze"
    method="POST"
    enctype="multipart/form-data"
    class="needs-validation"
    novalidate
  >
    <div class="middle-container">
      <!-- LEFT CARD -->
      <div class="resume-container">
        <h5>Your Resume</h5>
        <p>Upload a file or paste your resume text</p>

        <!-- FILE INPUT -->
        <label class="upload-box">
          <input type="file" name="resumeFile" hidden />
          <p>⬆ Drag & drop or <span>browse</span></p>
          <small>PDF, DOC, TXT</small>
        </label>

        <div class="divider">or paste below</div>

        <textarea
          name="resumeText"
          placeholder="Paste your resume content here..."
        ></textarea>
      </div>

      <!-- RIGHT CARD -->
      <div class="resume-container">
        <h5>Job Description</h5>
        <p>Paste the target job description</p>

        <textarea
          name="jobDescription"
          class="jd-box"
          placeholder="Paste the job description here..."
          required
        ></textarea>
        <!-- //bootstrap classes for success failure text -->
        <div class="valid-feedback">Looks Good!</div>
        <div class="invalid-feedback">Please enter the JD!</div>
      </div>
    </div>

    <!-- BUTTON -->
    <div class="analyze-btn">
      <button type="submit">⚡ Analyze Resume</button>
    </div>
  </form>

  <!-- BUTTON -->
  <div class="analyze-btn">
    <button>⚡ Analyze Resume</button>
  </div>
</div>

<script>
  const fileInput = document.querySelector('input[type="file"]');
  const uploadBox = document.querySelector(".upload-box p");

  fileInput.addEventListener("change", function () {
    if (this.files.length > 0) {
      uploadBox.textContent = this.files[0].name;
    }
  });
</script>
