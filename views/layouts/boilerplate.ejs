<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>InterviewPrep</title>

    <!-- CSS -->
    <link rel="stylesheet" href="/css/style.css" />

    <!-- Bootstrap -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Font Awesome -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.0/css/all.min.css"
    />
  </head>

  <body>

    <!-- NAVBAR -->
    <%- include("../includes/navbar.ejs") %>

    <!-- TOASTS -->
    <% if (success && success.length) { %>
      <div class="toast-wrapper">
        <div class="toast-success" id="success-toast">
          <div class="toast-icon">✓</div>
          <div class="toast-text"><%= success[0] %></div>
        </div>
      </div>
    <% } %>

    <% if (error && error.length) { %>
      <div class="toast-wrapper">
        <div class="toast-error" id="error-toast">
          <div class="toast-icon">!</div>
          <div class="toast-text"><%= error[0] %></div>
        </div>
      </div>
    <% } %>

    <!-- MAIN CONTENT -->
    <main id="page-content">
      <%- body %>
      <%- include("../includes/footer.ejs") %>
    </main>

    <!-- SCRIPTS -->
    <script>
      document.querySelectorAll(".toast-success, .toast-error").forEach((toast) => {
        setTimeout(() => {
          toast.classList.add("toast-hide");

          setTimeout(() => {
            toast.remove();
          }, 300);
        }, 2000);
      });
    </script>

    <script src="/js/script.js"></script>

  </body>
</html>