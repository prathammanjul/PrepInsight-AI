<% layout("/layouts/boilerplate") %>
<style>
  /* ================= PAGE ================= */

  body {
    background:
      radial-gradient(
        circle at 50% 30%,
        rgba(56, 189, 248, 0.15),
        transparent 55%
      ),
      radial-gradient(
        circle at 60% 50%,
        rgba(99, 102, 241, 0.1),
        transparent 60%
      ),
      #020617;

    color: white;
  }

  .topic-wrapper {
    padding: 100px 20px;
    text-align: center;
    color: white;
  }

  /* HEADER */
  .topic-header h1 {
    font-size: 3rem;
    font-weight: 600;
  }

  .topic-header span {
    color: #38bdf8;
  }

  .topic-header p {
    margin-top: 12px;
    color: #94a3b8;
    max-width: 520px;
    margin-inline: auto;
    font-size: 15px;
  }

  /* ================= GRID ================= */
  .topic-grid {
    margin-top: 60px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
    padding: 0 6rem;
  }

  /* ================= CARD ================= */
  .card {
    padding: 30px 20px;
    border-radius: 18px;

    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.08);

    text-decoration: none;
    color: white;

    transition: all 0.3s ease;
    position: relative;
  }

  /* GLOW HOVER (IMPORTANT 🔥) */
  .card:hover {
    transform: translateY(-6px);
    border-color: rgba(56, 189, 248, 0.4);
    box-shadow: 0 0 40px rgba(56, 189, 248, 0.15);
  }

  /* ================= ICON ================= */
  .icon {
    width: 55px;
    height: 55px;
    margin: 0 auto 18px;

    display: flex;
    align-items: center;
    justify-content: center;

    border-radius: 14px;
    font-size: 22px;
  }

  .blue {
    background: linear-gradient(135deg, #2563eb, #38bdf8);
  }
  .green {
    background: linear-gradient(135deg, #16a34a, #4ade80);
  }
  .orange {
    background: linear-gradient(135deg, #ea580c, #fb923c);
  }
  .yellow {
    background: linear-gradient(135deg, #ca8a04, #fde047);
  }
  .purple {
    background: linear-gradient(135deg, #9333ea, #c084fc);
  }
  .pink {
    background: linear-gradient(135deg, #db2777, #f472b6);
  }
  .indigo {
    background: linear-gradient(135deg, #4f46e5, #818cf8);
  }
  .gradient {
    background: linear-gradient(135deg, #ec4899, #8b5cf6);
  }

  /* TEXT */
  .card h3 {
    font-size: 18px;
    margin-bottom: 8px;
    color: white;
  }

  .card p {
    font-size: 13px;
    color: #94a3b8;
  }

  /* ================= BACK BUTTON ================= */
  .back-container {
    position: absolute;
    top: 90px;
    left: 60px;
    z-index: 10; /* prevent overlap issues */
  }

  .back-btn {
    display: inline-block;
    padding: 8px 16px;
    border-radius: 999px;

    text-decoration: none;
    font-size: 14px;
    color: #cbd5f5;

    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);

    transition: 0.3s;
    white-space: nowrap; /* prevents text breaking */
  }

  /* HOVER */
  .back-btn:hover {
    color: white;
    border-color: rgba(56, 189, 248, 0.4);
    box-shadow: 0 0 15px rgba(56, 189, 248, 0.2);
  }

  /* ================= RESPONSIVE ================= */

  /* ===== TABLET (<= 1024px) ===== */
  @media (max-width: 1024px) {
    .topic-grid {
      grid-template-columns: repeat(2, 1fr);
      padding: 0 2rem;
      gap: 22px;
    }

    .topic-header h1 {
      font-size: 2.5rem;
    }
    .back-container {
      top: 80px;
      left: 30px;
    }
    .back-btn {
      font-size: 13px;
      padding: 7px 14px;
    }
  }

  /* ===== MOBILE (<= 768px) ===== */
  @media (max-width: 768px) {
    .topic-wrapper {
      padding: 80px 15px;
    }

    .topic-grid {
      grid-template-columns: repeat(2, 1fr);
      padding: 0;
      gap: 18px;
    }

    .topic-header h1 {
      font-size: 2.2rem;
    }

    .topic-header p {
      font-size: 14px;
    }

    /* BACK BUTTON */
    .back-container {
      position: static;
      margin-bottom: 20px;
      text-align: left;
      padding-left: 10px;
    }

    .back-btn {
      font-size: 13px;
      padding: 6px 12px;
      margin-top: 4rem;
      display: flex;
      justify-content: center;
    }
  }

  /* ===== SMALL MOBILE (<= 480px) ===== */
  @media (max-width: 480px) {
    .topic-grid {
      grid-template-columns: 1fr;
    }

    .card {
      padding: 24px 16px;
    }

    .topic-header h1 {
      font-size: 1.8rem;
    }

    .icon {
      width: 48px;
      height: 48px;
      font-size: 18px;
    }
    .back-btn {
      font-size: 12px;
      padding: 6px 10px;
      /* background-color: orange; */
      margin-top: 4rem;
      display: flex;
      justify-content: center;
    }
  }
</style>
<% layout("/layouts/boilerplate") %>

