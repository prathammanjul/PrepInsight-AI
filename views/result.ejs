<% layout("/layouts/boilerplate") %> <% layout("/layouts/boilerplate") %>
<style>
  body {
    background:
      radial-gradient(
        circle at 50% 30%,
        rgba(56, 189, 248, 0.15),
        transparent 55%
      ),
      radial-gradient(
        circle at 60% 50%,
        rgba(99, 102, 241, 0.1),
        transparent 60%
      ),
      #020617;

    color: white;
  }

  /* ================= WRAPPER ================= */
  .result-wrapper {
    max-width: 800px;

    display: grid;
    justify-self: center;
    margin: 2rem 0rem 8rem 0rem;
    padding: 20px;
    color: white;
    text-align: center;
  }

  /* HEADER */
  .result-header h2 {
    font-size: 2.5rem;
    margin-bottom: 5px;
  }

  .result-header p {
    color: #94a3b8;
    font-size: 15px;
  }

  /* ================= SCORE CARD ================= */
  .score-card {
    margin: 30px 0;
    padding: 30px;

    background: rgba(0, 0, 0, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;

    box-shadow: 0 0 40px rgba(56, 189, 248, 0.1);
  }

  /* SCORE */
  .score {
    font-size: 4.5rem;
    font-weight: 700;
    color: #f59f0a;
  }

  .score-card p {
    color: #94a3b8;
    margin-bottom: 20px;
  }

  /* PROGRESS BAR */
  .score-bar {
    height: 6px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    overflow: hidden;
  }

  .score-fill {
    height: 100%;
    background: #f59f0a;

    transition: width 0.5s ease;
  }

  /* ================= FEEDBACK ================= */
  .feedback-section {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .feedback-card {
    text-align: left;
    padding: 18px;

    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
  }

  .feedback-card h4 {
    margin-bottom: 6px;
    font-size: 15px;
  }

  .feedback-card p {
    color: #94a3b8;
    font-size: 14px;
  }

  .feedback-card span {
    margin-right: 7px;
  }

  /* ================= BUTTONS ================= */
  .result-actions {
    margin-top: 30px;
    display: flex;
    justify-content: center;
    gap: 15px;
  }

  /* PRIMARY */
  .btn-primary {
    padding: 10px 20px;
    border-radius: 10px;
    text-decoration: none;

    background: linear-gradient(135deg, #3b82f6, #06b6d4);
    color: white;
    transition: 0.3s;
  }

  .btn-primary:hover {
    transform: scale(1.05);
  }

  /* SECONDARY */
  .btn-secondary {
    padding: 10px 20px;
    border-radius: 10px;
    text-decoration: none;

    border: 1px solid #334155;
    color: white;
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.05);
  }

  /* .strength {
    color: #22c55e !important;
    font-weight: bold;
    margin-right: 6px;
  } */
  .feedback-card h4 span .strength {
    color: #22c55e !important;
  }
  @media (max-width: 768px) {
    .result-actions {
      flex-direction: column;
    }

    .score {
      font-size: 2.2rem;
    }
  }
</style>
<div class="result-wrapper">
  <!-- HEADER -->
  <div class="result-header">
    <h2>Your Results</h2>
    <p><%= topic %> Interview</p>
  </div>

  <!-- SCORE CARD -->
  <div class="score-card">
    <h1 class="score"><%= feedback.match(/Score: (\d+)/)?.[1] || "0" %></h1>
    <p>out of 10</p>

    <div class="score-bar">
      <div
        class="score-fill"
        style="width: <%= (feedback.match(/Score: (\d+)/) ?.[1] || 0) * 10 %>%"
      ></div>
    </div>
  </div>

  <!-- FEEDBACK CARDS -->
  <div class="feedback-section">
    <!-- STRENGTH -->
    <div class="feedback-card">
      <h4><span>✅ </span> Strengths</h4>
      <p><%= feedback.match(/Strength: (.*)/)?.[1] || "N/A" %></p>
    </div>

    <!-- IMPROVE -->
    <div class="feedback-card">
      <h4><span>⚠️ </span> Areas to Improve</h4>
      <p><%= feedback.match(/Improve: (.*)/)?.[1] || "N/A" %></p>
    </div>

    <!-- PERFECT ANSWER -->
    <div class="feedback-card">
      <h4><span>🏆 </span> Perfect Answer</h4>
      <p><%= feedback.match(/Perfect Answer: (.*)/)?.[1] || "N/A" %></p>
    </div>

    <!-- USER ANSWER -->
    <div class="feedback-card">
      <h4><span>➡️ </span> Your Answer</h4>
      <p><%= answer %></p>
    </div>
  </div>

  <!-- ACTION BUTTONS -->
  <div class="result-actions">
    <a href="/interview/start?topic=<%= topic %>" class="btn-primary">
      🔁 Practice Again
    </a>

    <a href="/performance" class="btn-secondary"> View Performance → </a>
  </div>
</div>
