<% layout("/layouts/boilerplate") %>

<div class="container mt-5 d-flex justify-content-center">
  <div
    class="card shadow-lg p-4"
    style="max-width: 700px; width: 100%; border-radius: 16px"
  >
    <!-- YOUR ANSWER -->
    <h5 class="fw-bold mb-2">📝 Your Answer</h5>
    <p class="text-muted"><%= answer %></p>

    <hr />

    <!-- AI RESULT -->
    <h5 class="fw-bold mb-3">🤖 AI Evaluation</h5>

    <div class="mb-3">
      <span class="badge bg-dark fs-6 p-2">
        <%= feedback.match(/Score: \d+\/10/) %>
      </span>
    </div>

    <div class="mb-2">
      <strong class="text-success">✔ Strength:</strong>
      <p><%= feedback.match(/Strength: (.*)/)[1] %></p>
    </div>

    <div class="mb-2">
      <strong class="text-danger">⚠ Improve:</strong>
      <p><%= feedback.match(/Improve: (.*)/)[1] %></p>
    </div>

    <!-- NEXT BUTTON -->
    <div class="mt-4 text-end">
      <a href="/interview/start?topic=<%= topic %>" class="btn btn-dark">
        Next Question →
      </a>
    </div>
    <!-- PERFECT ANSWER -->
    <div class="mt-4 p-3 border rounded bg-light">
      <h6 class="fw-bold text-primary">💡 Perfect Interview Answer</h6>
      <p><%= feedback.match(/Perfect Answer: (.*)/)[1] %></p>
    </div>
  </div>
</div>
