<% layout("/layouts/boilerplate") %>
<link href="/css/result.css" rel="stylesheet" />
<style></style>
<div class="result-wrapper">
  <!-- HEADER -->
  <div class="result-header">
    <h2>Your Results</h2>
    <p><%= topic %> Interview</p>
  </div>

  <!-- SCORE CARD -->
  <div class="score-card">
    <h1 class="score"><%= feedback.match(/Score: (\d+)/)?.[1] || "0" %></h1>
    <p>out of 10</p>

    <div class="score-bar">
      <div
        class="score-fill"
        style="width: <%= (feedback.match(/Score: (\d+)/) ?.[1] || 0) * 10 %>%"
      ></div>
    </div>
  </div>

  <!-- FEEDBACK CARDS -->
  <div class="feedback-section">
    <!-- STRENGTH -->
    <div class="feedback-card">
      <h4><span>✅ </span> Strengths</h4>
      <p><%= feedback.match(/Strength: (.*)/)?.[1] || "N/A" %></p>
    </div>

    <!-- IMPROVE -->
    <div class="feedback-card">
      <h4><span>⚠️ </span> Areas to Improve</h4>
      <p><%= feedback.match(/Improve: (.*)/)?.[1] || "N/A" %></p>
    </div>

    <!-- PERFECT ANSWER -->
    <div class="feedback-card">
      <h4><span>🏆 </span> Perfect Answer</h4>
      <p><%= feedback.match(/Perfect Answer: (.*)/)?.[1] || "N/A" %></p>
    </div>

    <!-- USER ANSWER -->
    <div class="feedback-card">
      <h4><span>➡️ </span> Your Answer</h4>
      <p><%= answer %></p>
    </div>
  </div>

  <!-- ACTION BUTTONS -->
  <div class="result-actions">
    <a href="/interview/start?topic=<%= topic %>" class="btn-primary">
      🔁 Practice Again
    </a>

    <a href="/performance" class="btn-secondary"> View Performance → </a>
  </div>
</div>
