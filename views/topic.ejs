<% layout("/layouts/boilerplate") %>

<div
  class="d-flex justify-content-center align-items-center"
  style="min-height: 80vh"
>
  <div
    class="card shadow p-5 text-center"
    style="max-width: 500px; width: 100%; border-radius: 16px"
  >
    <h3 class="fw-bold text-capitalize"><%= topic %> Interview</h3>

    <p class="text-muted mt-3">
      Practice <%= topic %> questions and improve your skills with AI feedback.
    </p>

    <a
      href="/interview/start?topic=<%= topic %>"
      class="btn btn-dark btn-lg mt-4"
    >
      🚀 Start Interview
    </a>
  </div>
</div>
