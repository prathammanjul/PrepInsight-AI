<style>
  /* NAVBAR */
  .navbar-custom {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: center !important;
    padding: 15px 40px !important;

    background: #0a0f1e;
    color: white;
  }

  /* LOGO */
  .logo {
    margin: 0;
  }

  /* CENTER */
  .middle {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  /* LINKS */
  .buttons a {
    color: white;
    text-decoration: none;
    margin: 0 12px !important;
    position: relative !important;
  }

  /* HOVER */
  .buttons a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -5px;
    width: 0%;
    height: 2px;
    background: #58a6ff;
    transition: 0.3s;
  }

  .buttons a:hover::after {
    width: 100%;
  }

  /* RIGHT */
  .right button {
    margin-left: 10px !important;
    padding: 6px 14px !important;
    border-radius: 6px;
    border: none;
    cursor: pointer;
  }

  /* BUTTONS */
  .login-btn {
    background: transparent;
    border: 1px solid #58a6ff;
    color: white;
  }

  .signup-btn {
    background: linear-gradient(135deg, #58a6ff, #2ea043);
    color: white;
  }

  /* HAMBURGER */
  .menu-toggle {
    display: none;
    font-size: 24px;
    cursor: pointer;
  }

  /*  MOBILE MENU */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(6px);
    display: none;
    justify-content: center;
    align-items: flex-start;
    padding-top: 80px;
    z-index: 999;
  }

  .mobile-menu.active {
    display: flex;
  }

  /* CARD */
  .menu-card {
    width: 90%;
    max-width: 360px;
    background: linear-gradient(135deg, #0d1117, #161b22);
    border-radius: 15px;
    padding: 20px !important;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    color: white;
  }

  /* HEADER */
  .menu-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 20px !important;
  }

  .menu-header span {
    cursor: pointer;
  }

  /* LINKS */
  .menu-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .menu-links a {
    text-decoration: none;
    color: #c9d1d9;
    padding: 10px !important;
    border-radius: 8px;
  }

  .menu-links a.active {
    background: rgba(88, 166, 255, 0.2);
    color: #58a6ff;
  }

  .menu-links a:hover {
    background: rgba(88, 166, 255, 0.1);
  }

  /* AUTH */
  .menu-auth {
    margin-top: 20px !important;
    display: flex;
    gap: 10px;
  }

  .menu-auth button {
    flex: 1;
    padding: 8px !important;
    border-radius: 8px;
  }

  /*  RESPONSIVE */
  @media (max-width: 768px) {
    .menu-toggle {
      display: block;
    }

    .middle {
      display: none;
    }

    .right {
      display: none;
    }
  }
</style>

<nav class="navbar-custom">
  <!-- LEFT -->
  <div class="left">
    <h4 class="logo">🚀 InterviewPrep</h4>
  </div>

  <!-- HAMBURGER -->
  <div class="menu-toggle" onclick="openMenu()">☰</div>

  <!-- DESKTOP CENTER -->
  <div class="middle">
    <div class="buttons">
      <a href="/">Home</a>
      <a href="/interview">Practice</a>
      <a href="/performance">Performance</a>
    </div>
  </div>

  <!-- RIGHT -->
   <%if(!currUser)  {%>
    <div class="right buttons">
      <a href="/login">Login</a>
      <a href="/signup">Signup</a>
    </div>
   <%} else{ %>

    
    <div class="right buttons d-flex mt-2">
      <p class="me-4" >👋 <%=currUser.username  %></p>
      <a href="/logout">Logout</a>
    </div>


    <%}  %>
</nav>

<!--  MOBILE POPUP MENU -->
<div class="mobile-menu" id="mobileMenu">
  <div class="menu-card">
    <!-- HEADER -->
    <div class="menu-header">
      <h5>🚀 InterviewPrep</h5>
      <span onclick="closeMenu()">✕</span>
    </div>

    <!-- LINKS -->
    <div class="menu-links">
      <a href="/" class="active">Home</a>
      <a href="/interview">Practice</a>
      <a href="/performance">Performance</a>
    </div>

    <!-- AUTH -->
    <div class="menu-auth">
      <a class="login-btn">Log in</a>
      <button class="signup-btn">Sign up</button>
    </div>
  </div>
</div>

<script>
  function openMenu() {
    document.getElementById("mobileMenu").classList.add("active");
  }

  function closeMenu() {
    document.getElementById("mobileMenu").classList.remove("active");
  }

  // Close when clicking outside
  window.onclick = function (e) {
    const menu = document.getElementById("mobileMenu");
    if (e.target === menu) {
      closeMenu();
    }
  };
</script>
