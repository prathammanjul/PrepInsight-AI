<link href="/css/navbar.css" rel="stylesheet" />

<nav class="navbar-custom">

  <!-- LEFT -->
  <h4 class="logo">🚀 InterviewPrep</h4>

  <!-- HAMBURGER -->
  <div class="menu-toggle" onclick="openMenu()">☰</div>

  <!-- CENTER (DESKTOP) -->
  <div class="middle">
    <div class="buttons">
      <a href="/">Home</a>
      <a href="/interview">Practice</a>
      <a href="/performance">Performance</a>
      <a href="/resume">Resume</a>
    </div>
  </div>

  <!-- RIGHT (DESKTOP) -->
  <% if (!currUser) { %>
    <div class="right">
      <a href="/login" class="login-btn">Login</a>
      <a href="/signup" class="signup-btn">Signup</a>
    </div>
  <% } else { %>
    <div class="right">
      <span class="username">👋 <%= currUser.username %></span>
      <a class="logout" href="/logout">Logout</a>
    </div>
  <% } %>

</nav>

<!-- MOBILE MENU -->
<div class="mobile-menu" id="mobileMenu">
  <div class="menu-card">

    <div class="menu-header">
      <h5>🚀 InterviewPrep</h5>
      <span onclick="closeMenu()">✕</span>
    </div>

    <div class="menu-links">
      <a href="/">Home</a>
      <a href="/interview">Practice</a>
      <a href="/performance">Performance</a>
      <a href="/resume">Resume</a>
    </div>

    <% if (!currUser) { %>
      <div class="menu-auth">
        <a href="/login" class="login-btn">Login</a>
        <a href="/signup" class="signup-btn">Signup</a>
      </div>
    <% } else { %>
      <div class="menu-auth">
        <span>👋 <%= currUser.username %></span>
        <a class="logout" href="/logout">Logout</a>
      </div>
    <% } %>

  </div>
</div>

<script src="/js/navbar.js"></script>