<style>
/* ================= NAVBAR ================= */
.navbar-custom {
  position: sticky;
  top: 0;
  z-index: 1000; 

  display: flex;
  justify-content: space-between;
  align-items: center;

  padding: 15px 40px;
  background: #0a0f1e ;
  color: white;
}
/* LOGO */
.logo {
  margin: 0;
}

/* CENTER LINKS */
.middle {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.buttons {
  display: flex;
  align-items: center;
}

.buttons a {
  color: white;
  text-decoration: none;
  margin: 0 12px;
  position: relative;
}

/* HOVER EFFECT */
.buttons a::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -5px;
  width: 0%;
  height: 2px;
  background: #58a6ff;
  transition: 0.3s;
}

.buttons a:hover::after {
  width: 100%;
}

/* RIGHT */
.right {
  display: flex;
  align-items: center;
}

.right a {
  margin-left: 12px;
}

/* USER TEXT */
.username {
  margin-right: 10px;
  color: #94a3b8;
}

/* BUTTON STYLES */
.login-btn {

  padding: 6px 14px;
  border-radius: 6px;
  text-decoration: none;
  color: white;
}


.signup-btn {
  background: linear-gradient(135deg, #3b82f6, #06b6d4);
  color: white;
  text-decoration: none;
  padding: 6px 14px;
  border-radius: 6px;
  transition: 0.3s;
}

.signup-btn:hover{
  color: white;
  transform: scale(1.05);
}
.login-btn:hover {
  color: white;
  background: linear-gradient(135deg, #6fa2f3, #70d0e0);




}

/* HAMBURGER */
.menu-toggle {
  display: none;
  font-size: 24px;
  cursor: pointer;
}

/* ================= MOBILE MENU ================= */
.mobile-menu {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
  color: white;
  backdrop-filter: blur(6px);
  display: none;
  justify-content: center;
  align-items: flex-start;
  padding-top: 80px;
  z-index: 999;
}

.mobile-menu.active {
  display: flex;
}

.menu-card {
  width: 90%;
  max-width: 360px;
  background: linear-gradient(135deg, #0d1117, #161b22);
  border-radius: 15px;
  padding: 20px;
  box-shadow: 0 20px 50px rgba(0,0,0,0.5);
}

/* HEADER */
.menu-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20px;
}

/* LINKS */
.menu-links {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.menu-links a {
  color: #c9d1d9;
  padding: 10px;
  border-radius: 8px;
  text-decoration: none;
}

.menu-links a:hover {
  background: rgba(88,166,255,0.1);
}

/* AUTH */
.menu-auth {
  margin-top: 20px;
  display: flex;
  gap: 10px;

}
.menu-auth .logout , .right .logout {
background-color: red;
text-decoration: none;
color: white;
  background: linear-gradient(135deg, #3b82f6, #06b6d4);
  color: white;
  text-decoration: none;
  padding: 6px 14px;
  border-radius: 6px;

}

/* ================= RESPONSIVE ================= */

/* TABLET */
@media (max-width: 992px) {
  .middle {
    display: none;
  }

  .right {
    display: none;
  }

  .menu-toggle {
    display: block;

  }
  .menu-auth{
    flex-direction: column !important;
    
  }



}

/* MOBILE */
@media (max-width: 480px) {
  .navbar-custom {
    padding: 12px 20px;

  }

  .logo {
    font-size: 16px;
  }
  .menu-auth{
    flex-direction: column !important;
    
  }

}
</style>

<nav class="navbar-custom">

  <!-- LEFT -->
  <h4 class="logo">🚀 InterviewPrep</h4>

  <!-- HAMBURGER -->
  <div class="menu-toggle" onclick="openMenu()">☰</div>

  <!-- CENTER (DESKTOP) -->
  <div class="middle">
    <div class="buttons">
      <a href="/">Home</a>
      <a href="/interview">Practice</a>
      <a href="/performance">Performance</a>
      <a href="/resume">Resume</a>
    </div>
  </div>

  <!-- RIGHT (DESKTOP) -->
  <% if (!currUser) { %>
    <div class="right">
      <a href="/login" class="login-btn">Login</a>
      <a href="/signup" class="signup-btn">Signup</a>
    </div>
  <% } else { %>
    <div class="right">
      <span class="username">👋 <%= currUser.username %></span>
      <a class="logout" href="/logout">Logout</a>
    </div>
  <% } %>

</nav>

<!-- MOBILE MENU -->
<div class="mobile-menu" id="mobileMenu">
  <div class="menu-card">

    <div class="menu-header">
      <h5>🚀 InterviewPrep</h5>
      <span onclick="closeMenu()">✕</span>
    </div>

    <div class="menu-links">
      <a href="/">Home</a>
      <a href="/interview">Practice</a>
      <a href="/performance">Performance</a>
      <a href="/resume">Resume</a>
    </div>

    <% if (!currUser) { %>
      <div class="menu-auth">
        <a href="/login" class="login-btn">Login</a>
        <a href="/signup" class="signup-btn">Signup</a>
      </div>
    <% } else { %>
      <div class="menu-auth">
        <span>👋 <%= currUser.username %></span>
        <a class="logout" href="/logout">Logout</a>
      </div>
    <% } %>

  </div>
</div>

<script>
function openMenu() {
  document.getElementById("mobileMenu").classList.add("active");
}

function closeMenu() {
  document.getElementById("mobileMenu").classList.remove("active");
}

window.onclick = function(e) {
  const menu = document.getElementById("mobileMenu");
  if (e.target === menu) closeMenu();
};
</script>