<% layout("/layouts/boilerplate") %>
<link href="/css/interview.css" rel="stylesheet" />
<div class="interview-wrapper">
  <!-- TOP BAR -->
  <div class="top-bar">
    <div class="progress-text"><%=topic %> Interview</div>
    <div class="timer">⏱ <span id="timerBox">5</span></div>
  </div>

  <!-- PROGRESS BAR -->
  <div class="progress-bar-container">
    <div class="progress-bar-fill" id="progressBar"></div>
  </div>
<p>Questions remaining: <%= remaining %></p>
  <!-- QUESTION CARD -->
  <div class="question-card">
    <h3><%= question %></h3>
  </div>

  <!-- FORM -->
  <form action="/interview" method="POST" class="answer-section">
    <input type="hidden" name="topic" value="<%= topic %>" />
    <input type="hidden" name="question" value="<%= question %>" />

    <!-- TEXTAREA -->
    <textarea
      name="answer"
      id="answer-input"
      placeholder="Type your answer here..."
      required
    ></textarea>

    <!-- FOOTER -->
    <div class="answer-footer">
      <span id="count">0 characters</span>

      <button class="submit-btn">🚀 Submit Answer</button>
    </div>
  </form>
</div>

<script src="/js/interview.js"> 
